# ──────────────────────────────────────────────────────────────
# Figma API Ingestor — Variables de Entorno (Plantilla)
# ──────────────────────────────────────────────────────────────
# Copia este archivo exactamente como ".env" (sin .example) y 
# rellena los valores. NUNCA subas el archivo .env real al repositorio.

# Token personal de acceso a la API de Figma
# Encuéntralo en: Figma → Account Settings → Personal Access Tokens
FIGMA_API_TOKEN=TU_TOKEN_DE_ACCESO_AQUI

# ID del archivo de Figma que quieres descargar
# Está en la URL: figma.com/file/AQUI_VA_EL_ID/nombre-del-archivo
FIGMA_FILE_ID=ID_DEL_ARCHIVO_AQUI
